# read-together 환경변수 예시
# 실제 배포 시 이 파일을 .env 로 복사하고 값을 채워넣으세요.
# 주의: .env 파일은 절대 git에 커밋하지 마세요.

# ── 필수 ──────────────────────────────────────────────────────────────────────

# 세션 쿠키 서명 키 (HMAC-SHA256, RQ-NFR-SEC-02)
# 생성: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── 선택 (기본값 있음) ─────────────────────────────────────────────────────────

# SQLite DB 파일 경로 (Docker 볼륨 마운트 경로 기준)
DB_PATH=/data/read_together.db

# Uvicorn 바인딩 포트
PORT=8000

# Uvicorn 로그 레벨: debug | info | warning | error
LOG_LEVEL=info

# CORS 허용 출처 (운영 시 명시 필요, MVP 내부망은 * 허용)
# 예시: https://book.example.com
ALLOWED_ORIGINS=*
